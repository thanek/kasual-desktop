# Kasual Desktop app entry — copy to ~/.config/kasual-desktop/apps/
[Desktop Entry]
Type=Application
Name=Pliki
# Bundled app: set Exec to the ABSOLUTE path of the launcher (the file lives in
# the cloned repo, e.g. /home/you/kasual/apps/file_browser/file_browser.sh).
Exec=/path/to/kasual/apps/file_browser/file_browser.sh
X-Kasual-Icon=fa5s.folder-open
X-Kasual-Color=#5e81ac
X-Kasual-Order=40
