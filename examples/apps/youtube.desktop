# Kasual Desktop app entry — copy to ~/.config/kasual-desktop/apps/
[Desktop Entry]
Type=Application
Name=YouTube
# Bundled app: set Exec to the ABSOLUTE path of the launcher (the file lives in
# the cloned repo, e.g. /home/you/kasual/apps/yt/yt.sh). Relative paths will not
# resolve once this entry is in ~/.config.
Exec=/path/to/kasual/apps/yt/yt.sh
X-Kasual-Icon=fa5b.youtube
X-Kasual-Color=#c0392b
X-Kasual-Order=30
